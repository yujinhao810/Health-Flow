# Shared
NODE_ENV=development

# API
API_PORT=3001
DATABASE_URL=postgresql://health:health@localhost:5432/health_assistant
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
JWT_ACCESS_TTL=30d
ENCRYPTION_KEY=change-me-32-bytes-long-at-least
CORS_ORIGIN=http://localhost:5173

# LLM provider
# 可选 provider：mock, ollama, anthropic, openai, google, mistral, cohere, groq, xai, openrouter,
# deepseek, moonshot, qwen, zhipu, baidu, tencent, volcengine。
LLM_PROVIDER=mock
LLM_MODEL=mock-health-assistant
LLM_VISION_ENABLED=false
# 留空时使用供应商内置默认 Base URL；也可用 LLM_BASE_URL 或 <PROVIDER>_BASE_URL 覆盖。
LLM_BASE_URL=
# 可选：单独指定 RAG 文档向量化使用的 Embedding API，不填则复用当前模型供应商配置。
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# Uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,image/bmp,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,text/plain,text/markdown,application/json,text/csv

# API keys are optional unless you select that provider. Never commit real keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=
BAIDU_API_KEY=
TENCENT_API_KEY=
VOLCENGINE_API_KEY=

# Optional provider-specific Base URL overrides
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
MISTRAL_BASE_URL=
COHERE_BASE_URL=
GROQ_BASE_URL=
XAI_BASE_URL=
OPENROUTER_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434/v1
DEEPSEEK_BASE_URL=
MOONSHOT_BASE_URL=
QWEN_BASE_URL=
ZHIPU_BASE_URL=
BAIDU_BASE_URL=
TENCENT_BASE_URL=
VOLCENGINE_BASE_URL=
