# Copy to .env.production. Never commit the real file.
NODE_ENV=production
API_PORT=3001

# Keep POSTGRES_PASSWORD URL-safe and use exactly the same value in DATABASE_URL.
POSTGRES_USER=health
POSTGRES_PASSWORD=replace-with-a-long-url-safe-db-password
POSTGRES_DB=health_assistant
DATABASE_URL=postgresql://health:replace-with-a-long-url-safe-db-password@postgres:5432/health_assistant
REDIS_URL=redis://redis:6379

# Generate independent random values of at least 32 characters.
JWT_SECRET=replace-with-a-random-jwt-secret-at-least-32-chars
JWT_ACCESS_TTL=2h
ENCRYPTION_KEY=replace-with-a-random-encryption-key-at-least-32-chars

# Public HTTPS URL supplied by your hosting platform or TLS reverse proxy.
CORS_ORIGIN=https://health.example.com
WEB_BASE_URL=https://health.example.com
WEB_PORT=8080

# QQ Mail example. URL-encode the username/password when they contain special characters.
SMTP_URL=smtp://your-qq-number%40qq.com:replace-with-qq-smtp-auth-code@smtp.qq.com:465
SMTP_FROM=HealthFlow <your-qq-number@qq.com>
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000

# Optional first-deployment admin. Uncomment both, deploy once, then remove ADMIN_PASSWORD.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=replace-with-a-long-random-password

LLM_PROVIDER=mock
LLM_MODEL=mock-health-assistant
LLM_VISION_ENABLED=false
ALLOW_CUSTOM_LLM_BASE_URLS=false
RAG_RERANK_ENABLED=false
DOCUMENT_PARSER_URL=http://document-parser:8090
DOCUMENT_PARSER_TIMEOUT_MS=180000
DOCUMENT_PARSER_MIN_QUALITY=0.55
DOCUMENT_PARSER_ALLOW_TEXT_FALLBACK=true
DOCUMENT_PARSER_ALLOW_PDF_FALLBACK=true

MAX_UPLOAD_BYTES=10485760
MAX_AVATAR_BYTES=2097152
